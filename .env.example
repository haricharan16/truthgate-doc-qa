# ──────────────────────────────────────────────
# Get your FREE Gemini API key at:
# https://aistudio.google.com/apikey
# ──────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# Optional overrides (defaults shown)
CHROMA_PERSIST_DIR=./data/chroma
CORPUS_CACHE_DIR=./data/corpus
LOG_LEVEL=INFO
COST_LOG_FILE=./logs/cost_log.jsonl

# Refusal thresholds (tuned — change carefully)
SIMILARITY_THRESHOLD=0.35
TOP_K_RETRIEVAL=8
TOP_K_RERANK=3

# Gemini models used
# Free tier limits: 15 RPM, 1M TPM for gemini-1.5-flash
GEMINI_EMBED_MODEL=models/text-embedding-004
GEMINI_CHAT_MODEL=gemini-1.5-flash
